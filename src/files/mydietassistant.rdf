                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasGlycemicIndex"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
