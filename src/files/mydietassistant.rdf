<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant/"
     xml:base="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:mydietassistant="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant">
        <rdfs:comment>Recipe ontology</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#avoidsFood -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#avoidsFood">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#containsNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#containsNutrient">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Nutrient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#forbidsIngredient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#forbidsIngredient">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isForbiddenFor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCondition">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isAllergicTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isAllergicTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isConditionFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isConditionFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isForbiddenFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isForbiddenFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#recommendedDiet -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#recommendedDiet">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#requiresNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#requiresNutrient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Nutrient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#shouldAvoid -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#shouldAvoid">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Nutrient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasAge -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasAge">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCalories -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCalories">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasDescription -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasFat -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasFat">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasGlycemicIndex -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasGlycemicIndex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasMaxCarbContent -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasMaxCarbContent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasName">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Person"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasProtein -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasProtein">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Anemia -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Anemia">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#HealthCondition"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#isConditionFor"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#AnemiaFriendlyRecipe"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#requiresNutrient"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Iron"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#AnemiaFriendlyRecipe -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#AnemiaFriendlyRecipe">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Ingredient"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#containsNutrient"/>
                                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Iron"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Recipe"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Anemia"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Asparagus -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Asparagus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Vegetable"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Avocado -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Avocado">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Fruit"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCalories"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">160</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasFat"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasProtein"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#BakedSalmonAsparagus -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#BakedSalmonAsparagus">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#NamedRecipe"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Asparagus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Salmon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#CeliacDisease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Diabetes"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#suitedForCondition"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Obesity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasIngredient"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Asparagus"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Salmon"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCalories"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">450</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasGlycemicIndex"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Broccoli -->

    <owl:Class rdf:about="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Broccoli">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#Vegetable"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasCalories"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">33</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/duygu/ontologies/2026/3/mydietassistant#hasProtein"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</owl:hasValue>
            </owl:Restriction>
